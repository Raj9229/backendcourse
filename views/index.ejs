<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    
</head>
<body>
    <h1>Welcome to the Index Page</h1>

    <% files.forEach(function(file) { %>
        <p><%= file %></p>
        <a href="/edit/<%= file %>">Edit</a>
        <a href="/delete/<%= file %>">Delete</a>
    <% }); %>  




</body>
</html>
